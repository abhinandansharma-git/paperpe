# PaperPe Environment Variables
# Copy this to .env.local and fill in your values

# ============================================
# SECURITY (REQUIRED)
# ============================================

# JWT secret for signing tokens (min 32 chars, use: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# ============================================
# DATABASE (When ready)
# ============================================

# DATABASE_URL=postgresql://user:password@localhost:5432/paperpe

# ============================================
# EXTERNAL SERVICES
# ============================================

# Email service (for waitlist confirmations)
# RESEND_API_KEY=re_xxxxx

# Analytics
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# MARKET DATA (Future)
# ============================================

# Angel One API
# ANGEL_API_KEY=
# ANGEL_CLIENT_ID=

# Dhan API  
# DHAN_CLIENT_ID=
# DHAN_ACCESS_TOKEN=
