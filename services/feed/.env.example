# PaperPe Real-Time Feed Configuration
# Copy to .env and fill in your broker credentials

# Redis
REDIS_URL=redis://localhost:6379

# ========================================
# OPTION 1: Shoonya/Finvasia (FREE)
# https://shoonya.com - Open free account
# ========================================
SHOONYA_USER_ID=
SHOONYA_PASSWORD=
SHOONYA_TOTP_SECRET=
SHOONYA_VENDOR_CODE=
SHOONYA_API_KEY=

# ========================================
# OPTION 2: Fyers (FREE with account)
# https://fyers.in
# ========================================
FYERS_CLIENT_ID=
FYERS_ACCESS_TOKEN=

# ========================================
# OPTION 3: Angel One
# https://www.angelone.in
# ========================================
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# ========================================
# Frontend
# ========================================
NEXT_PUBLIC_FEED_URL=http://localhost:8001
